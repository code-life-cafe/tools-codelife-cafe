---
import { getRelatedTools, toolCatalog } from '../../lib/tools/catalog';
import ToolCard from '../common/ToolCard.astro';

interface Props {
	toolId?: string;
	relatedSlugs?: string[];
}

const { toolId, relatedSlugs } = Astro.props;

// ツールIDから、またはrelatedSlugsから、catalog.tsのgetRelatedToolsロジックを用いて関連ツールを取得（同カテゴリ補完含む）
let validTools: ReturnType<typeof getRelatedTools> = [];

if (toolId) {
	validTools = getRelatedTools(toolId, 3);
} else if (relatedSlugs && relatedSlugs.length > 0) {
	const firstSlug = relatedSlugs[0].replace(/^\//, '');
	const found = toolCatalog.find((t) => t.id === firstSlug || t.href === `/${firstSlug}`);
	if (found) {
		validTools = getRelatedTools(found.id, 3);
	}
}
---

{validTools.length > 0 && (
	<section id="related-tools-section" class="mt-8" aria-labelledby="related-tools-heading">
		<h2 id="related-tools-heading" class="text-lg font-semibold mb-4 text-foreground">
			関連ツール
		</h2>
		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
			{validTools.map((t) => (
				<ToolCard
					id={t.id}
					title={t.title}
					description={t.description}
					href={t.href}
					icon={t.icon}
					category={t.category}
					categoryColor={t.categoryColor}
				/>
			))}
		</div>
	</section>
)}
